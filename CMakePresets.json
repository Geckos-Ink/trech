{
  "version": 6,
  "configurePresets": [
    {
      "name": "dev",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "TRECH_ENABLE_GEANT4": "ON",
        "TRECH_FETCH_DEPS": "ON"
      }
    },
    {
      "name": "rel",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/rel",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "TRECH_ENABLE_GEANT4": "ON",
        "TRECH_FETCH_DEPS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev"
    },
    {
      "name": "rel",
      "configurePreset": "rel"
    }
  ]
}
